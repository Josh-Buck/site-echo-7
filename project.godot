; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Site Echo 7"
config/description="Stationary 360° horde shooter. Draft research-note cards between rounds. Site Echo-7 outbreak."
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://autoload/GameState.gd"
MetaProgress="*res://autoload/MetaProgress.gd"
EventBus="*res://autoload/EventBus.gd"
AudioMan="*res://autoload/AudioMan.gd"
SaveSystem="*res://autoload/SaveSystem.gd"
CardSystem="*res://autoload/CardSystem.gd"
ChallengeTracker="*res://autoload/ChallengeTracker.gd"
ChallengeToast="*res://scenes/ui/ChallengeToast.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

